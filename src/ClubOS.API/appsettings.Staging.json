{
  "ConnectionStrings": {
    "DefaultConnection": "Host=${POSTGRES_HOST};Port=5432;Database=${POSTGRES_DB};Username=${POSTGRES_USER};Password=${POSTGRES_PASSWORD}",
    "Redis": "${REDIS_HOST}:6379"
  },
  "Jwt": {
    "Issuer":    "${JWT_ISSUER}",
    "Audience":  "${JWT_AUDIENCE}",
    "SecretKey": "${JWT_SECRET_KEY}"
  },
  "AllowedOrigins": ["${FRONTEND_URL}"],
  "Serilog": {
    "MinimumLevel": "Warning"
  }
}
