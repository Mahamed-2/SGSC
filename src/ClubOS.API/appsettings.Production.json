{
  "ConnectionStrings": {
    "DefaultConnection": "Host=${POSTGRES_HOST};Port=5432;Database=${POSTGRES_DB};Username=${POSTGRES_USER};Password=${POSTGRES_PASSWORD};SSL Mode=Require;Trust Server Certificate=false",
    "Redis": "${REDIS_HOST}:6380,ssl=true,abortConnect=false"
  },
  "Jwt": {
    "Issuer":          "${JWT_ISSUER}",
    "Audience":        "${JWT_AUDIENCE}",
    "SecretKey":       "${JWT_SECRET_KEY}",
    "ExpiryMinutes":   30,
    "RefreshTokenExpiryDays": 3
  },
  "AllowedOrigins": ["${FRONTEND_URL}"],
  "FeatureFlags": {
    "EnableKpiTracking":      true,
    "EnableFeedbackPortal":   true,
    "EnableAuditLog":         true,
    "EnableMultiTenantCache": true
  },
  "Serilog": {
    "MinimumLevel": "Warning"
  }
}
